#!/usr/bin/env python3
"""qmcp.AttachDeviceAIManaged — attach a virtual device from one ai-managed
qube (backend) to another ai-managed qube (frontend).

Stage E1. Both endpoints must be ai-managed; the wrapper collapses
"backend missing", "backend not ai-managed", "frontend missing", and
"frontend not ai-managed" to the same opaque "not found" so AI cannot
use the device surface as an existence oracle for untagged qubes
(matching qmcp.GetPropertyAIManaged / qmcp.LifecycleAIManaged).

Input  (stdin, JSON): {
    "device_class": "block" | "usb" | "mic",
    "backend":      "<ai-managed qube exposing the device>",
    "device_id":    "<port_id as enumerated by admin.vm.device.<class>.Available>",
    "frontend":     "<ai-managed qube to attach the device to>",
    "options":      { "<key>": "<value>", ... }   (optional; class-specific)
}

Output (stdout, JSON):
    {"ok": true}
    {"ok": false, "error": "not found"}     -- backend or frontend missing/untagged
    {"ok": false, "error": "<reason>"}

Implementation: dom0-side tag check via qubesadmin, then attach via the
`qvm-device <class> attach <frontend> <backend>:<port_id>` CLI. Shelling
out to qvm-device absorbs Qubes-version drift in the DeviceAssignment
Python API (the class moved between qubesadmin.devices and
qubes.device_protocol across 4.1 → 4.2 → 4.3); qvm-device is the
canonical stable surface from 4.1 onward.

The trust invariant (both ends ai-managed) is enforced here in dom0
with qubesadmin authority before any qvm-device call runs.
"""
from __future__ import annotations

import json
import shutil
import subprocess
import sys

ALLOWED_CLASSES = {"block", "usb", "mic"}
NOT_FOUND = {"ok": False, "error": "not found"}


def emit(payload: dict) -> int:
    print(json.dumps(payload))
    return 0 if payload.get("ok") else 1


def normalise_mic_port(device_class: str, device_id: str) -> str:
    # The Qubes mic class has a single port whose id is conventionally "mic".
    # Accept an empty string for convenience and substitute it.
    if device_class == "mic" and not device_id:
        return "mic"
    return device_id


def main() -> int:
    try:
        req = json.loads(sys.stdin.read() or "{}")
    except Exception as e:
        return emit({"ok": False, "error": f"invalid JSON input: {e}"})

    device_class = req.get("device_class", "")
    backend = req.get("backend", "")
    device_id = req.get("device_id", "")
    frontend = req.get("frontend", "")
    options = req.get("options") or {}

    if device_class not in ALLOWED_CLASSES:
        return emit({"ok": False,
                     "error": f"device_class must be one of: {sorted(ALLOWED_CLASSES)}"})
    if not isinstance(options, dict):
        return emit({"ok": False, "error": "options must be an object"})

    device_id = normalise_mic_port(device_class, device_id)
    if not device_id:
        return emit({"ok": False, "error": "device_id is required"})
    if not backend or not frontend:
        return emit(NOT_FOUND)

    try:
        import qubesadmin.app
        app = qubesadmin.app.QubesLocal()
    except Exception as e:
        return emit({"ok": False, "error": f"qubesadmin import failed: {e}"})

    # Both endpoints must exist AND be ai-managed. Collapse the two
    # negative cases to the same opaque "not found".
    for name in (backend, frontend):
        if name not in app.domains:
            return emit(NOT_FOUND)
        if "ai-managed" not in app.domains[name].tags:
            return emit(NOT_FOUND)

    if shutil.which("qvm-device") is None:
        return emit({"ok": False, "error": "qvm-device CLI not present in dom0"})

    cmd = ["qvm-device", device_class, "attach", frontend, f"{backend}:{device_id}"]
    for k, v in options.items():
        cmd += ["-o", f"{k}={v}"]

    try:
        proc = subprocess.run(cmd, capture_output=True, timeout=30)
    except subprocess.TimeoutExpired:
        return emit({"ok": False, "error": "qvm-device attach timed out"})
    except Exception as e:
        return emit({"ok": False, "error": f"qvm-device attach failed to launch: {e}"})

    if proc.returncode != 0:
        msg = (proc.stderr.decode(errors="replace").strip()
               or proc.stdout.decode(errors="replace").strip()
               or f"qvm-device exit {proc.returncode}")
        return emit({"ok": False, "error": f"attach failed: {msg}"})

    return emit({"ok": True})


if __name__ == "__main__":
    sys.exit(main())
